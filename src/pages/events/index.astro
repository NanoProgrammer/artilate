---
import Layout from '../../layouts/Layout.astro'
export const prerender = true;
const seoData = {
  title: 'Weddings & Events — Artilate',
  description: 'Artisan chocolate wedding favours & gift boxes for your guests. Plus tastings, workshops & corporate events in Calgary.',
  noindex: false
}
const otherEvents = [
  { date:'2025-09-14', title:'Chocolate & Origins Tasting', where:'Calgary Pop-up', note:'Guided flight of 4 origins + bonbon pairing', tag:'Tasting' },
  { date:'2025-10-05', title:'Bonbon Finishing Workshop', where:'Airdrie Kitchen', note:'Hands-on shelling, fillings, and temper', tag:'Workshop' },
]
---

<Layout {...seoData}>
  <main class="events-page">

    <!-- ═══════════  HERO — WEDDING  ═══════════ -->
    <section class="wedding-hero">
      <div class="hero-overlay"></div>
      <div class="hero-particles" aria-hidden="true">
        <span class="hp hp1"></span><span class="hp hp2"></span><span class="hp hp3"></span>
        <span class="hp hp4"></span><span class="hp hp5"></span><span class="hp hp6"></span>
        <span class="hp hp7"></span><span class="hp hp8"></span>
      </div>

      <div class="container hero-inner">
        <p class="hero-eyebrow">Artilate for your</p>
        <h1 class="hero-title">Wedding</h1>
        <p class="hero-sub">Unique gifts for your guests — single-origin artisan bonbons presented in custom boxes that reflect your celebration.</p>
        <a href="#wedding-inquiry" class="hero-cta">Get in Touch&ensp;↓</a>
      </div>
    </section>

    <!-- ═══════════  WEDDING IMAGE + FEATURES  ═══════════ -->
    <section class="wedding-showcase">
      <div class="container showcase-grid">
        <div class="showcase-image">
          <img
            src="/assets/wedding-showcase.jpeg"
            alt="Custom artisan bonbon boxes as wedding guest favours"
            loading="lazy"
            width="800" height="534"
          />
          <div class="img-badge">Bean to Bonbon</div>
        </div>
        <div class="showcase-features">
          <h2>Details your guests<br/>will remember</h2>
          <ul class="feature-list">
            <li>
              <span class="feat-icon">◆</span>
              <div><strong>Personalised Favours</strong><br/>Hand-selected bonbons packaged in boxes with your names, date, or monogram.</div>
            </li>
            <li>
              <span class="feat-icon">◆</span>
              <div><strong>Custom Packaging</strong><br/>Colours, ribbons, and finishes matched to your wedding palette — every box is a keepsake.</div>
            </li>
            <li>
              <span class="feat-icon">◆</span>
              <div><strong>Single-Origin Flavours</strong><br/>Cacao from Colombia — your guests will taste something they won't find anywhere else.</div>
            </li>
            <li>
              <span class="feat-icon">◆</span>
              <div><strong>Any Wedding Size</strong><br/>From intimate gatherings of 20 to celebrations of 300+ — we adapt to what you need.</div>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- ═══════════  WEDDING INQUIRY FORM (Netlify)  ═══════════ -->
    <section class="wedding-form-section" id="wedding-inquiry">
      <div class="container form-container">
        <div class="form-intro">
          <h2>Tell us about your wedding</h2>
          <p>Leave your details and we'll send you a custom proposal within 48 hours.</p>
        </div>

        <form
          name="wedding-inquiry"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="inquiry-form"
        >
          <input type="hidden" name="form-name" value="wedding-inquiry" />
          <p class="hidden-honey" aria-hidden="true">
            <label>Don't fill this out: <input name="bot-field" /></label>
          </p>

          <div class="form-row">
            <div class="field">
              <label for="name">Name</label>
              <input type="text" id="name" name="name" required placeholder="Your name" />
            </div>
            <div class="field">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" required placeholder="you@example.com" />
            </div>
          </div>

          <div class="form-row">
            <div class="field">
              <label for="date">Wedding Date</label>
              <input type="date" id="date" name="wedding-date" />
            </div>
            <div class="field">
              <label for="guests">Guest Count</label>
              <input type="number" id="guests" name="guest-count" min="1" placeholder="e.g. 120" />
            </div>
          </div>

          <div class="field full-width">
            <label for="details">Anything else we should know?</label>
            <textarea id="details" name="details" rows="3" placeholder="Colour palette, flavour preferences, dietary needs…"></textarea>
          </div>

          <button type="submit" class="primary-btn submit-btn">Send Inquiry</button>
        </form>
      </div>
    </section>

    <!-- ═══════════  OTHER EVENTS  ═══════════ -->
    <section class="other-events">
      <div class="container">
        <div class="section-header">
          <p class="section-eyebrow">Beyond weddings</p>
          <h2>Events & Experiences</h2>
          <p class="section-sub">Guided tastings, hands-on workshops, and pop-ups — join the next session or book one for your group.</p>
        </div>

        <div class="events-grid">
          {otherEvents.map((e) => (
            <article class="event-card-lg">
              <div class="card-top">
                <span class="event-tag">{e.tag}</span>
                <span class="event-date-lg">{new Date(e.date).toLocaleDateString(undefined,{month:'long', day:'numeric', year:'numeric'})}</span>
              </div>
              <h3>{e.title}</h3>
              <p class="card-where">{e.where}</p>
              <p class="card-note">{e.note}</p>
              <a href="/contact" class="card-btn">Reserve a Spot</a>
            </article>
          ))}

          <article class="event-card-lg cta-card">
            <div class="card-top">
              <span class="event-tag">Private</span>
            </div>
            <h3>Host your own event</h3>
            <p class="card-note">Corporate tastings, team-builds, or private celebrations — we design a bespoke experience for your group.</p>
            <div class="cta-card-actions">
              <a
                href="https://mail.google.com/mail/?view=cm&fs=1&to=admin@artilate.com&su=Private%20Event%20-%20Artilate"
                target="_blank" rel="noopener"
                class="card-btn"
              >Get in Touch</a>
              <a href="/wholesale" class="card-btn-ghost">Corporate Gifting →</a>
            </div>
          </article>
        </div>
      </div>
    </section>

  </main>

  <style>
    :root {
      --cacao:#0A0B0D; --ivory:#FAFAF9; --gold:#D4A373; --amber:#F59E0B;
      --rose:#C9A9A6; --muted:rgba(250,250,249,.65); --glass:rgba(20,22,24,.55);
    }
    body{ background:var(--cacao); color:var(--ivory); line-height:1.6; overflow-x:hidden; }
    .container{ max-width:1200px; margin:0 auto; padding:0 2rem; }
    .hidden-honey{ display:none; }

    /* ── HERO ── */
    .wedding-hero{
      position:relative; min-height:92vh; display:flex; align-items:center; justify-content:center;
      text-align:center; overflow:hidden;
      background:
        radial-gradient(ellipse at 30% 20%, rgba(201,169,166,.10) 0%, transparent 55%),
        radial-gradient(ellipse at 70% 75%, rgba(212,163,115,.08) 0%, transparent 55%),
        var(--cacao);
    }
    .hero-overlay{
      position:absolute; inset:0;
      background:repeating-linear-gradient(135deg, transparent, transparent 60px, rgba(212,163,115,.015) 60px, rgba(212,163,115,.015) 61px);
      pointer-events:none;
    }
    .hero-particles{ position:absolute; inset:0; pointer-events:none; }
    .hp{ position:absolute; width:5px; height:5px; border-radius:50%; background:var(--gold); opacity:0; animation:sparkle 5s ease-in-out infinite; }
    .hp1{ top:12%; left:18%; animation-delay:0s }
    .hp2{ top:28%; left:76%; animation-delay:.7s }
    .hp3{ top:65%; left:12%; animation-delay:1.4s }
    .hp4{ top:78%; left:82%; animation-delay:2.1s }
    .hp5{ top:40%; left:90%; animation-delay:2.8s }
    .hp6{ top:88%; left:45%; animation-delay:3.5s }
    .hp7{ top:18%; left:55%; animation-delay:4.2s }
    .hp8{ top:55%; left:30%; animation-delay:4.8s }
    @keyframes sparkle{
      0%,100%{ opacity:0; transform:scale(.6) translateY(0) }
      50%{ opacity:.55; transform:scale(1.1) translateY(-14px) }
    }
    .hero-inner{ position:relative; z-index:2; max-width:700px; }
    .hero-eyebrow{
      font-family:'Cormorant Garamond','Playfair Display',serif;
      font-size:1.15rem; letter-spacing:.18em; text-transform:uppercase; color:var(--rose);
      opacity:0; animation:fadeUp .8s ease-out .3s forwards;
    }
    .hero-title{
      font-family:'Playfair Display',serif; font-size:clamp(2.8rem,7vw,5rem);
      font-weight:600; margin:.25rem 0 1rem;
      background:linear-gradient(135deg, var(--ivory) 30%, var(--gold) 100%);
      -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
      opacity:0; animation:fadeUp .9s ease-out .6s forwards;
    }
    .hero-sub{
      font-size:1.1rem; color:var(--muted); max-width:560px; margin:0 auto 2rem;
      line-height:1.75; opacity:0; animation:fadeUp .8s ease-out .9s forwards;
    }
    .hero-cta{
      display:inline-block; padding:14px 36px; border:1px solid var(--gold); border-radius:60px;
      color:var(--gold); text-decoration:none; font-weight:600; letter-spacing:.06em;
      transition:all .4s cubic-bezier(.16,1,.3,1);
      opacity:0; animation:fadeUp .8s ease-out 1.2s forwards;
    }
    .hero-cta:hover{ background:var(--gold); color:var(--cacao); transform:translateY(-2px); box-shadow:0 8px 28px rgba(212,163,115,.3); }
    @keyframes fadeUp{ to{ opacity:1; transform:translateY(0) } }
    .hero-eyebrow,.hero-sub,.hero-cta{ transform:translateY(18px); }
    .hero-title{ transform:translateY(24px); }

    /* ── SHOWCASE ── */
    .wedding-showcase{ padding:6rem 0; }
    .showcase-grid{ display:grid; grid-template-columns:1fr 1fr; gap:3.5rem; align-items:center; }
    .showcase-image{
      position:relative; border-radius:20px; overflow:hidden;
      box-shadow:0 20px 60px rgba(0,0,0,.35);
    }
    .showcase-image img{ width:100%; height:auto; display:block; object-fit:cover; }
    .img-badge{
      position:absolute; bottom:16px; left:16px; background:rgba(10,11,13,.7); backdrop-filter:blur(10px);
      padding:6px 14px; border-radius:40px; font-size:.78rem; letter-spacing:.08em; text-transform:uppercase; color:var(--gold);
      border:1px solid rgba(212,163,115,.25);
    }
    .showcase-features h2{
      font-family:'Playfair Display',serif; font-size:clamp(1.6rem,3vw,2.2rem); margin-bottom:1.8rem; line-height:1.25;
    }
    .feature-list{ list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:1.25rem; }
    .feature-list li{ display:flex; gap:.85rem; align-items:flex-start; }
    .feat-icon{ color:var(--gold); font-size:.65rem; margin-top:.45rem; flex-shrink:0; }
    .feature-list strong{ color:var(--ivory); }
    .feature-list div{ color:var(--muted); font-size:.97rem; line-height:1.55; }

    /* ── FORM ── */
    .wedding-form-section{
      padding:5rem 0;
      background:
        radial-gradient(ellipse at 50% 0%, rgba(201,169,166,.07) 0%, transparent 60%),
        linear-gradient(180deg, rgba(212,163,115,.03) 0%, transparent 40%);
    }
    .form-container{ max-width:680px; }
    .form-intro{ text-align:center; margin-bottom:2.5rem; }
    .form-intro h2{
      font-family:'Playfair Display',serif; font-size:clamp(1.5rem,3vw,2.1rem); margin-bottom:.6rem;
    }
    .form-intro p{ color:var(--muted); max-width:460px; margin:0 auto; }
    .inquiry-form{ display:flex; flex-direction:column; gap:1.25rem; }
    .form-row{ display:grid; grid-template-columns:1fr 1fr; gap:1.25rem; }
    .field{ display:flex; flex-direction:column; gap:.35rem; }
    .field.full-width{ grid-column:1/-1; }
    label{ font-size:.82rem; letter-spacing:.06em; text-transform:uppercase; color:var(--muted); }
    input,select,textarea{
      background:var(--glass); border:1px solid rgba(212,163,115,.18); border-radius:10px;
      padding:12px 14px; color:var(--ivory); font-size:.95rem; font-family:inherit;
      transition:border-color .3s, box-shadow .3s;
    }
    input::placeholder,textarea::placeholder{ color:rgba(250,250,249,.3); }
    input:focus,select:focus,textarea:focus{
      outline:none; border-color:var(--gold);
      box-shadow:0 0 0 3px rgba(212,163,115,.12);
    }
    .submit-btn{
      align-self:center; margin-top:.5rem; cursor:pointer; border:none; font-size:1rem;
      padding:15px 44px; border-radius:60px;
      background:linear-gradient(135deg,var(--gold) 0%,var(--amber) 100%);
      color:var(--cacao); font-weight:700; letter-spacing:.04em;
      box-shadow:0 8px 30px rgba(212,163,115,.3);
      transition:all .4s cubic-bezier(.16,1,.3,1);
    }
    .submit-btn:hover{ transform:translateY(-3px); box-shadow:0 12px 40px rgba(212,163,115,.45); }

    /* ── OTHER EVENTS ── */
    .other-events{
      padding:6rem 0 5rem;
      background:
        radial-gradient(ellipse at 20% 80%, rgba(212,163,115,.05) 0%, transparent 50%),
        radial-gradient(ellipse at 80% 20%, rgba(201,169,166,.06) 0%, transparent 50%);
    }
    .section-header{ text-align:center; margin-bottom:3rem; }
    .section-eyebrow{
      font-family:'Cormorant Garamond','Playfair Display',serif;
      font-size:.95rem; letter-spacing:.16em; text-transform:uppercase; color:var(--rose); margin-bottom:.35rem;
    }
    .section-header h2{
      font-family:'Playfair Display',serif; font-size:clamp(1.6rem,3.5vw,2.4rem); margin-bottom:.6rem;
    }
    .section-sub{ color:var(--muted); max-width:520px; margin:0 auto; }
    .events-grid{
      display:grid; grid-template-columns:repeat(3, 1fr); gap:1.5rem;
      max-width:1060px; margin:0 auto;
    }
    .event-card-lg{
      border:1px solid rgba(212,163,115,.16); background:var(--glass); backdrop-filter:blur(8px);
      border-radius:18px; padding:1.75rem 1.5rem; display:flex; flex-direction:column;
      transition:border-color .35s, transform .35s, box-shadow .35s;
    }
    .event-card-lg:hover{
      border-color:rgba(212,163,115,.35); transform:translateY(-4px);
      box-shadow:0 16px 48px rgba(0,0,0,.25);
    }
    .card-top{ display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem; }
    .event-tag{
      font-size:.72rem; letter-spacing:.1em; text-transform:uppercase; color:var(--gold);
      background:rgba(212,163,115,.1); padding:4px 10px; border-radius:20px;
      border:1px solid rgba(212,163,115,.2);
    }
    .event-date-lg{ font-size:.82rem; color:var(--muted); }
    .event-card-lg h3{
      font-family:'Playfair Display',serif; font-size:1.2rem; margin:0 0 .4rem; line-height:1.3;
    }
    .card-where{ color:var(--gold); font-size:.88rem; margin:0 0 .35rem; font-weight:500; }
    .card-note{ color:var(--muted); font-size:.9rem; margin:0 0 1.25rem; line-height:1.55; flex-grow:1; }
    .card-btn{
      display:inline-block; padding:10px 22px; border:1px solid rgba(212,163,115,.3);
      border-radius:10px; color:var(--ivory); text-decoration:none; font-weight:600; font-size:.88rem;
      text-align:center; transition:all .35s cubic-bezier(.16,1,.3,1);
    }
    .card-btn:hover{ background:var(--gold); color:var(--cacao); border-color:var(--gold); }
    .cta-card{ border-style:dashed; border-color:rgba(212,163,115,.25); background:rgba(212,163,115,.04); }
    .cta-card-actions{ display:flex; flex-direction:column; gap:.6rem; }
    .card-btn-ghost{
      text-decoration:none; color:var(--gold); font-size:.88rem; font-weight:500;
      text-align:center; padding:6px 0; transition:opacity .3s;
    }
    .card-btn-ghost:hover{ opacity:.7; }

    /* ── SHARED ── */
    .primary-btn{
      border-radius:12px; padding:13px 26px; font-weight:600; text-decoration:none;
      display:inline-flex; align-items:center; gap:8px;
      transition:all .4s cubic-bezier(.16,1,.3,1);
      background:linear-gradient(135deg,var(--gold),var(--amber)); color:var(--cacao);
      box-shadow:0 8px 32px rgba(212,163,115,.3);
    }
    .primary-btn:hover{ transform:translateY(-3px); box-shadow:0 12px 40px rgba(212,163,115,.4); }

    @media(max-width:900px){
      .showcase-grid{ grid-template-columns:1fr; gap:2.5rem; }
      .showcase-image{ max-width:520px; margin:0 auto; }
      .events-grid{ grid-template-columns:1fr 1fr; }
    }
    @media(max-width:640px){
      .container{ padding:0 1.25rem; }
      .form-row{ grid-template-columns:1fr; }
      .events-grid{ grid-template-columns:1fr; max-width:420px; }
      .primary-btn{ width:100%; max-width:300px; justify-content:center; }
    }
  </style>
</Layout>