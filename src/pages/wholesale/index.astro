---
import Layout from '../../layouts/Layout.astro'
export const prerender = true;
const seoData = {
  title: 'Wholesale — Artilate',
  description: 'Partner with Artilate for curated chocolate assortments, custom co-branding, Colombian cacao beans, and Alberta-first logistics.',
  noindex: false
}
---

<Layout {...seoData}>
  <main class="wholesale-page">

    <!-- ═══════════  HERO  ═══════════ -->
    <section class="ws-hero">
      <div class="hero-overlay"></div>
      <div class="hero-particles" aria-hidden="true">
        <span class="hp hp1"></span><span class="hp hp2"></span><span class="hp hp3"></span>
        <span class="hp hp4"></span><span class="hp hp5"></span><span class="hp hp6"></span>
      </div>
      <div class="container hero-inner">
        <p class="hero-eyebrow">Wholesale & B2B</p>
        <h1 class="hero-title">Partner with Artilate</h1>
        <p class="hero-sub">Artisan chocolate for retail, hotels, corporate gifting, and events — produced in Alberta with single-origin cacao.</p>
        <div class="hero-actions">
          <a href="#wholesale-form" class="hero-cta-primary">Request Catalog&ensp;↓</a>
          <a href="/beans" class="hero-cta-secondary">Colombian Cacao Beans →</a>
        </div>
      </div>
    </section>

    <!-- ═══════════  BEANS BANNER  ═══════════ -->
    <section class="beans-banner">
      <div class="container banner-inner">
        <div class="banner-text">
          <span class="banner-tag">New</span>
          <h2>Colombian Cacao Beans</h2>
          <p>We sell fine-aroma cacao beans sourced directly from Colombian farms. Ideal for chocolatiers, pastry shops, and artisan producers.</p>
          <a href="/beans" class="banner-link">View varieties & pricing →</a>
        </div>
        <div class="banner-visual" aria-hidden="true">
          <svg viewBox="0 0 140 140" class="bean-svg">
            <ellipse cx="70" cy="70" rx="38" ry="52" fill="none" stroke="var(--gold)" stroke-width="1.5" opacity=".35" transform="rotate(-18 70 70)"/>
            <path d="M70,22 Q67,70 70,118" stroke="var(--gold)" stroke-width="1.2" fill="none" opacity=".5"/>
            <ellipse cx="70" cy="70" rx="26" ry="40" fill="none" stroke="var(--amber)" stroke-width=".8" opacity=".2" transform="rotate(-18 70 70)"/>
          </svg>
        </div>
      </div>
    </section>

    <!-- ═══════════  VALUE PROPS  ═══════════ -->
    <section class="ws-features">
      <div class="container">
        <div class="section-header">
          <p class="section-eyebrow">Wholesale Chocolate</p>
          <h2>What We Offer</h2>
        </div>
        <div class="features-grid">
          <article class="feat-card">
            <div class="feat-number">01</div>
            <h3>Curated Assortments</h3>
            <p>Best-sellers and seasonal sets designed for high sell-through and shelf appeal.</p>
          </article>
          
          <article class="feat-card">
            <div class="feat-number">02</div>
            <h3>Lead Times</h3>
            <p>Typically 2–4 weeks depending on volume and seasonality. Rush options subject to availability.</p>
          </article>
          <article class="feat-card">
            <div class="feat-number">03</div>
            <h3>MOQs & Pricing</h3>
            <p>MOQ varies by product; tiered pricing for scale. Request our current catalog for details.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- ═══════════  WHOLESALE FORM (Netlify)  ═══════════ -->
    <section class="ws-form-section" id="wholesale-form">
      <div class="container form-container">
        <div class="form-intro">
          <h2>Wholesale Inquiry</h2>
          <p>Tell us about your business and we'll send you our catalog, pricing, and terms.</p>
        </div>

        <form
          name="wholesale-inquiry"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="inquiry-form"
        >
          <input type="hidden" name="form-name" value="wholesale-inquiry" />
          <p class="hidden-honey" aria-hidden="true">
            <label>Don't fill this out: <input name="bot-field" /></label>
          </p>

          <div class="form-row">
            <div class="field">
              <label for="ws-name">Name</label>
              <input type="text" id="ws-name" name="name" required placeholder="Your name" />
            </div>
            <div class="field">
              <label for="ws-email">Email</label>
              <input type="email" id="ws-email" name="email" required placeholder="you@company.com" />
            </div>
          </div>

          <div class="form-row">
            <div class="field">
              <label for="ws-company">Company / Business</label>
              <input type="text" id="ws-company" name="company" placeholder="Your business name" />
            </div>
            <div class="field">
              <label for="ws-interest">Interest</label>
              <select id="ws-interest" name="interest">
                <option value="">Select…</option>
                <option value="chocolate">Wholesale Chocolate</option>
                <option value="beans">Cacao Beans</option>
                <option value="both">Both</option>
                <option value="other">Other</option>
              </select>
            </div>
          </div>

          <div class="field full-width">
            <label for="ws-details">Anything else?</label>
            <textarea id="ws-details" name="details" rows="3" placeholder="Volume estimates, product interests, timeline…"></textarea>
          </div>

          <button type="submit" class="primary-btn submit-btn">Send Inquiry</button>
        </form>
      </div>
    </section>

    <!-- ═══════════  BOTTOM CTA  ═══════════ -->
    <section class="ws-bottom">
      <div class="container bottom-row">
        <a href="/events" class="bottom-link">Corporate Events →</a>
        <a href="/beans" class="bottom-link">Cacao Beans →</a>
        <a href="/contact" class="bottom-link">General Contact →</a>
      </div>
    </section>

  </main>

  <style>
    :root {
      --cacao:#0A0B0D; --ivory:#FAFAF9; --gold:#D4A373; --amber:#F59E0B;
      --rose:#C9A9A6; --muted:rgba(250,250,249,.65); --glass:rgba(20,22,24,.55);
    }
    body{ background:var(--cacao); color:var(--ivory); line-height:1.6; overflow-x:hidden; }
    .container{ max-width:1200px; margin:0 auto; padding:0 2rem; }
    .hidden-honey{ display:none; }

    /* ── HERO ── */
    .ws-hero{
      position:relative; min-height:88vh; display:flex; align-items:center; justify-content:center;
      text-align:center; overflow:hidden;
      background:
        radial-gradient(ellipse at 25% 25%, rgba(212,163,115,.08) 0%, transparent 55%),
        radial-gradient(ellipse at 75% 70%, rgba(201,169,166,.07) 0%, transparent 55%),
        var(--cacao);
    }
    .hero-overlay{
      position:absolute; inset:0;
      background:repeating-linear-gradient(135deg, transparent, transparent 60px, rgba(212,163,115,.012) 60px, rgba(212,163,115,.012) 61px);
      pointer-events:none;
    }
    .hero-particles{ position:absolute; inset:0; pointer-events:none; }
    .hp{ position:absolute; width:5px; height:5px; border-radius:50%; background:var(--gold); opacity:0; animation:sparkle 5s ease-in-out infinite; }
    .hp1{ top:15%; left:20%; animation-delay:0s }
    .hp2{ top:30%; left:80%; animation-delay:.8s }
    .hp3{ top:70%; left:15%; animation-delay:1.6s }
    .hp4{ top:80%; left:75%; animation-delay:2.4s }
    .hp5{ top:45%; left:88%; animation-delay:3.2s }
    .hp6{ top:85%; left:50%; animation-delay:4s }
    @keyframes sparkle{
      0%,100%{ opacity:0; transform:scale(.6) translateY(0) }
      50%{ opacity:.5; transform:scale(1.1) translateY(-14px) }
    }
    .hero-inner{ position:relative; z-index:2; max-width:720px; }
    .hero-eyebrow{
      font-family:'Cormorant Garamond','Playfair Display',serif;
      font-size:1.1rem; letter-spacing:.18em; text-transform:uppercase; color:var(--rose);
      opacity:0; animation:fadeUp .8s ease-out .3s forwards;
    }
    .hero-title{
      font-family:'Playfair Display',serif; font-size:clamp(2.4rem,6vw,4.2rem);
      font-weight:600; margin:.3rem 0 1rem;
      background:linear-gradient(135deg, var(--ivory) 30%, var(--gold) 100%);
      -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
      opacity:0; animation:fadeUp .9s ease-out .6s forwards;
    }
    .hero-sub{
      font-size:1.1rem; color:var(--muted); max-width:560px; margin:0 auto 2rem;
      line-height:1.75; opacity:0; animation:fadeUp .8s ease-out .9s forwards;
    }
    .hero-actions{
      display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;
      opacity:0; animation:fadeUp .8s ease-out 1.2s forwards;
    }
    .hero-cta-primary{
      display:inline-block; padding:14px 34px; border-radius:60px;
      background:linear-gradient(135deg,var(--gold),var(--amber)); color:var(--cacao);
      text-decoration:none; font-weight:700; letter-spacing:.04em;
      box-shadow:0 8px 28px rgba(212,163,115,.3);
      transition:all .4s cubic-bezier(.16,1,.3,1);
    }
    .hero-cta-primary:hover{ transform:translateY(-2px); box-shadow:0 12px 36px rgba(212,163,115,.45); }
    .hero-cta-secondary{
      display:inline-block; padding:14px 34px; border:1px solid var(--gold); border-radius:60px;
      color:var(--gold); text-decoration:none; font-weight:600; letter-spacing:.04em;
      transition:all .4s cubic-bezier(.16,1,.3,1);
    }
    .hero-cta-secondary:hover{ background:var(--gold); color:var(--cacao); transform:translateY(-2px); }
    @keyframes fadeUp{ to{ opacity:1; transform:translateY(0) } }
    .hero-eyebrow,.hero-sub,.hero-actions{ transform:translateY(18px); }
    .hero-title{ transform:translateY(24px); }

    /* ── BEANS BANNER ── */
    .beans-banner{
      padding:3.5rem 0;
      background:linear-gradient(180deg, rgba(212,163,115,.04) 0%, transparent 100%);
    }
    .banner-inner{
      display:flex; align-items:center; gap:2.5rem;
      border:1px solid rgba(212,163,115,.2); background:rgba(212,163,115,.04);
      backdrop-filter:blur(8px); border-radius:20px; padding:2rem 2.5rem;
      transition:border-color .35s;
    }
    .banner-inner:hover{ border-color:rgba(212,163,115,.35); }
    .banner-text{ flex:1; }
    .banner-tag{
      display:inline-block; font-size:.7rem; letter-spacing:.12em; text-transform:uppercase;
      color:var(--cacao); background:var(--gold); padding:3px 10px; border-radius:20px;
      font-weight:700; margin-bottom:.75rem;
    }
    .banner-text h2{
      font-family:'Playfair Display',serif; font-size:clamp(1.3rem,2.5vw,1.8rem);
      margin:0 0 .5rem; line-height:1.3;
    }
    .banner-text p{ color:var(--muted); font-size:.95rem; line-height:1.6; margin:0 0 1rem; }
    .banner-link{
      color:var(--gold); text-decoration:none; font-weight:600; font-size:.95rem;
      transition:opacity .3s;
    }
    .banner-link:hover{ opacity:.7; }
    .banner-visual{ flex-shrink:0; }
    .bean-svg{ width:100px; height:100px; }

    /* ── FEATURES ── */
    .ws-features{ padding:5rem 0; }
    .section-header{ text-align:center; margin-bottom:2.5rem; }
    .section-eyebrow{
      font-family:'Cormorant Garamond','Playfair Display',serif;
      font-size:.95rem; letter-spacing:.16em; text-transform:uppercase; color:var(--rose); margin-bottom:.35rem;
    }
    .section-header h2{
      font-family:'Playfair Display',serif; font-size:clamp(1.5rem,3vw,2.2rem);
    }
    .features-grid{
      display:grid; grid-template-columns:repeat(2, 1fr); gap:1.25rem;
      max-width:900px; margin:0 auto;
    }
    .feat-card{
      border:1px solid rgba(212,163,115,.16); background:var(--glass); backdrop-filter:blur(8px);
      border-radius:16px; padding:1.5rem 1.4rem;
      transition:border-color .35s, transform .35s;
    }
    .feat-card:hover{ border-color:rgba(212,163,115,.35); transform:translateY(-3px); }
    .feat-number{
      font-family:'Cormorant Garamond','Playfair Display',serif;
      font-size:1.8rem; font-weight:700; color:var(--gold); opacity:.5; line-height:1; margin-bottom:.5rem;
    }
    .feat-card h3{ font-size:1.05rem; margin:0 0 .35rem; }
    .feat-card p{ color:var(--muted); font-size:.9rem; line-height:1.55; margin:0; }

    /* ── FORM ── */
    .ws-form-section{
      padding:5rem 0;
      background:
        radial-gradient(ellipse at 50% 0%, rgba(201,169,166,.07) 0%, transparent 60%),
        linear-gradient(180deg, rgba(212,163,115,.03) 0%, transparent 40%);
    }
    .form-container{ max-width:700px; }
    .form-intro{ text-align:center; margin-bottom:2.5rem; }
    .form-intro h2{
      font-family:'Playfair Display',serif; font-size:clamp(1.5rem,3vw,2.1rem); margin-bottom:.6rem;
    }
    .form-intro p{ color:var(--muted); max-width:460px; margin:0 auto; }
    .inquiry-form{ display:flex; flex-direction:column; gap:1.25rem; }
    .form-row{ display:grid; grid-template-columns:1fr 1fr; gap:1.25rem; }
    .field{ display:flex; flex-direction:column; gap:.35rem; }
    .field.full-width{ grid-column:1/-1; }
    label{ font-size:.82rem; letter-spacing:.06em; text-transform:uppercase; color:var(--muted); }
    input,select,textarea{
      background:var(--glass); border:1px solid rgba(212,163,115,.18); border-radius:10px;
      padding:12px 14px; color:var(--ivory); font-size:.95rem; font-family:inherit;
      transition:border-color .3s, box-shadow .3s;
    }
    input::placeholder,textarea::placeholder{ color:rgba(250,250,249,.3); }
    input:focus,select:focus,textarea:focus{
      outline:none; border-color:var(--gold);
      box-shadow:0 0 0 3px rgba(212,163,115,.12);
    }
    select{ cursor:pointer; }
    select option{ background:var(--cacao); }
    .submit-btn{
      align-self:center; margin-top:.5rem; cursor:pointer; border:none; font-size:1rem;
      padding:15px 44px; border-radius:60px;
      background:linear-gradient(135deg,var(--gold) 0%,var(--amber) 100%);
      color:var(--cacao); font-weight:700; letter-spacing:.04em;
      box-shadow:0 8px 30px rgba(212,163,115,.3);
      transition:all .4s cubic-bezier(.16,1,.3,1);
    }
    .submit-btn:hover{ transform:translateY(-3px); box-shadow:0 12px 40px rgba(212,163,115,.45); }

    /* ── BOTTOM LINKS ── */
    .ws-bottom{ padding:3rem 0 4rem; }
    .bottom-row{
      display:flex; gap:2rem; justify-content:center; flex-wrap:wrap;
    }
    .bottom-link{
      color:var(--gold); text-decoration:none; font-weight:600; font-size:.95rem;
      padding:10px 24px; border:1px solid rgba(212,163,115,.2); border-radius:10px;
      transition:all .35s cubic-bezier(.16,1,.3,1);
    }
    .bottom-link:hover{ background:rgba(212,163,115,.08); border-color:rgba(212,163,115,.4); transform:translateY(-2px); }

    /* ── SHARED ── */
    .primary-btn{
      border-radius:12px; padding:13px 26px; font-weight:600; text-decoration:none;
      display:inline-flex; align-items:center; gap:8px;
      transition:all .4s cubic-bezier(.16,1,.3,1);
      background:linear-gradient(135deg,var(--gold),var(--amber)); color:var(--cacao);
      box-shadow:0 8px 32px rgba(212,163,115,.3);
    }
    .primary-btn:hover{ transform:translateY(-3px); box-shadow:0 12px 40px rgba(212,163,115,.4); }

    @media(max-width:900px){
      .banner-inner{ flex-direction:column; text-align:center; gap:1.5rem; }
    }
    @media(max-width:640px){
      .container{ padding:0 1.25rem; }
      .form-row{ grid-template-columns:1fr; }
      .features-grid{ grid-template-columns:1fr; }
      .hero-actions{ flex-direction:column; align-items:center; }
      .hero-cta-primary,.hero-cta-secondary{ width:100%; max-width:300px; text-align:center; }
      .bottom-row{ flex-direction:column; align-items:center; }
      .bottom-link{ width:100%; max-width:280px; text-align:center; }
    }
  </style>
</Layout>